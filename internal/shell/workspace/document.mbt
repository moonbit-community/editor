///|
/// Provider-owned immutable document content for one URI/revision.
pub(all) struct DocumentSnapshot {
  uri : @base_common.Uri
  display_name : String
  language_id : String
  revision : String
  text : String
  line_starts : Array[Int]
} derive(Debug)

///|
/// Document-level failure with optional URI context.
pub(all) struct DocumentError {
  code : FileSystemProviderErrorCode
  message : String
  uri : @base_common.Uri?
} derive(Debug)

///|
/// Provider read result without exceptions.
pub(all) enum DocumentReadResult {
  DocumentLoaded(DocumentSnapshot)
  DocumentNotFound(@base_common.Uri)
  DocumentReadFailed(DocumentError)
} derive(Debug)

///|
/// Push notification from a provider watch or host-owned watcher.
pub(all) enum DocumentChange {
  DocumentInvalidated(uri~ : @base_common.Uri, known_revision~ : String?)
  DocumentUpdated(DocumentSnapshot)
  DocumentDeleted(@base_common.Uri)
  DocumentChangeFailed(uri~ : @base_common.Uri, error~ : DocumentError)
} derive(Debug)

///|
/// Document source contract for the readonly viewer. Providers may coalesce
/// watch updates and can either invalidate a URI or provide a fresh snapshot.
pub(open) trait DocumentProvider {
  async fn read(Self, @base_common.Uri) -> DocumentReadResult
  fn watch(Self, @base_common.Uri, (DocumentChange) -> Unit) -> @base_common.Disposable
  fn close(Self, @base_common.Uri) -> Unit
}

///|
/// Builds a document error, defaulting an empty message to the code label.
pub fn DocumentError::DocumentError(
  code : FileSystemProviderErrorCode,
  message : String,
  uri? : @base_common.Uri,
) -> DocumentError {
  let message = if message == "" { code.to_string() } else { message }
  { code, message, uri }
}

///|
/// Converts a lower-level filesystem provider failure into a document error.
pub fn DocumentError::from_file_system_error(
  error : FileSystemProviderError,
) -> DocumentError {
  { code: error.code, message: error.message, uri: error.uri }
}

///|
/// Converts a document error back to the lower-level error shape when protocol
/// adapters need the existing provider-code JSON format.
pub fn DocumentError::to_file_system_error(
  self : DocumentError,
) -> FileSystemProviderError {
  { code: self.code, message: self.message, uri: self.uri }
}

///|
/// Builds a normalized immutable document snapshot.
pub fn DocumentSnapshot::DocumentSnapshot(
  uri : @base_common.Uri,
  display_name : String,
  language_id : String,
  revision : String,
  text : String,
) -> DocumentSnapshot {
  let display_name = if display_name == "" {
    @base_common.basename_or_authority(uri)
  } else {
    display_name
  }
  let language_id = if language_id == "" {
    infer_language_id(display_name)
  } else {
    language_id
  }
  let revision = if revision == "" {
    revision_from_text(text)
  } else {
    revision
  }
  {
    uri,
    display_name,
    language_id,
    revision,
    text,
    line_starts: build_line_starts(text),
  }
}

///|
/// Derives a snapshot from provider content, filling display name, language id,
/// and revision when they are absent.
pub fn DocumentSnapshot::from_content(
  uri : @base_common.Uri,
  content : DocumentContent,
) -> DocumentSnapshot {
  DocumentSnapshot(
    uri,
    content.display_name,
    content.language_id,
    content.revision,
    content.text,
  )
}

///|
/// Snapshot length in the repo's JavaScript-compatible UTF-16 indexing model.
pub fn DocumentSnapshot::length(self : DocumentSnapshot) -> Int {
  self.text.length()
}

///|
/// Number of logical lines, including the final empty line after a trailing
/// newline.
pub fn DocumentSnapshot::line_count(self : DocumentSnapshot) -> Int {
  self.line_starts.length()
}

///|
/// Start offset for `line`, clamped into the snapshot's line range.
pub fn DocumentSnapshot::line_start_offset(
  self : DocumentSnapshot,
  line : Int,
) -> Int {
  let line = @base_common.clamp_int(line, 0, self.line_count() - 1)
  self.line_starts[line]
}

///|
/// End offset for `line`, clamped into the snapshot's line range and excluding
/// the line break. CRLF lines exclude both the `\r` and `\n`.
pub fn DocumentSnapshot::line_end_offset(
  self : DocumentSnapshot,
  line : Int,
) -> Int {
  let line = @base_common.clamp_int(line, 0, self.line_count() - 1)
  let raw_end = if line + 1 < self.line_count() {
    self.line_starts[line + 1] - 1
  } else {
    self.length()
  }
  if raw_end > self.line_starts[line] && self.text[raw_end - 1].to_int() == 13 {
    raw_end - 1
  } else {
    raw_end
  }
}

///|
/// Text of one logical line without its line break.
pub fn DocumentSnapshot::line_text(
  self : DocumentSnapshot,
  line : Int,
) -> String {
  let start = self.line_start_offset(line)
  let end = self.line_end_offset(line)
  self.text[start:end].to_owned()
}

///|
/// Returns a clamped half-open slice of the snapshot text.
pub fn DocumentSnapshot::slice(
  self : DocumentSnapshot,
  range : @base_common.OffsetRange,
) -> String {
  let start = @base_common.clamp_int(range.start, 0, self.length())
  let end = @base_common.clamp_int(range.end_exclusive, start, self.length())
  self.text[start:end].to_owned()
}

///|
/// Zero-based line containing `offset`, with out-of-range offsets clamped to
/// the snapshot.
pub fn DocumentSnapshot::line_at_offset(
  self : DocumentSnapshot,
  offset : Int,
) -> Int {
  let offset = @base_common.clamp_int(offset, 0, self.length())
  let mut found = 0
  for i in 0..<self.line_starts.length() {
    if self.line_starts[i] <= offset {
      found = i
    }
  }
  found
}

///|
/// Converts an offset to a one-based line/column `Position` (Monaco's
/// convention; the offset↔position boundary adds +1 on both axes).
pub fn DocumentSnapshot::position_at_offset(
  self : DocumentSnapshot,
  offset : Int,
) -> @base_common.Position {
  let offset = @base_common.clamp_int(offset, 0, self.length())
  let line = self.line_at_offset(offset)
  { line_number: line + 1, column: offset - self.line_starts[line] + 1 }
}

///|
/// Converts a one-based line/column `Position` to a clamped document offset,
/// undoing the +1 this boundary added in `position_at_offset`.
pub fn DocumentSnapshot::offset_at_position(
  self : DocumentSnapshot,
  position : @base_common.Position,
) -> Int {
  let line = @base_common.clamp_int(
    position.line_number - 1,
    0,
    self.line_count() - 1,
  )
  let start = self.line_start_offset(line)
  let end = self.line_end_offset(line)
  @base_common.clamp_int(start + position.column - 1, start, end)
}

///|
/// JSON shape emitted to browser harnesses and remote protocol adapters.
pub impl ToJson for DocumentSnapshot with fn to_json(self) {
  {
    "uri": self.uri.to_string().to_json(),
    "displayName": self.display_name.to_json(),
    "languageId": self.language_id.to_json(),
    "revision": self.revision.to_json(),
    "text": self.text.to_json(),
  }
}

///|
/// JSON shape for document read results.
pub impl ToJson for DocumentReadResult with fn to_json(self) {
  match self {
    DocumentLoaded(document) => { "ok": true, "document": document.to_json() }
    DocumentNotFound(uri) =>
      { "ok": false, "notFound": true, "uri": uri.to_string().to_json() }
    DocumentReadFailed(error) => { "ok": false, "error": error.to_json() }
  }
}

///|
/// JSON shape for document errors.
pub impl ToJson for DocumentError with fn to_json(self) {
  let fields : Map[String, Json] = {
    "code": self.code.to_string().to_json(),
    "message": self.message.to_json(),
    "status": self.status().to_json(),
  }
  match self.uri {
    Some(uri) => {
      fields["uri"] = uri.to_string().to_json()
      fields["displayName"] = @base_common.basename_or_authority(uri).to_json()
    }
    None => ()
  }
  Json::object(fields)
}

///|
/// HTTP-like status used by the reference server when serializing document
/// failures.
pub fn DocumentError::status(self : DocumentError) -> Int {
  self.to_file_system_error().status()
}

///|
/// Offsets where each line begins (0-based). Mirrors Monaco's
/// `createLineStartsFast` (`pieceTreeBase.ts:37`): `\n`, a lonely `\r`
/// (classic-Mac CR EOL), and `\r\n` each end a line, with the `\r\n` pair
/// counted as one line break. Byte-identical copy in
/// `viewer/common/model/text_snapshot.mbt`; the two straddle the product/shell
/// boundary, so they are intentionally not unified but must change together.
fn build_line_starts(text : String) -> Array[Int] {
  let starts = [0]
  let len = text.length()
  let mut i = 0
  while i < len {
    let code = text[i].to_int()
    if code == 13 {
      if i + 1 < len && text[i + 1].to_int() == 10 {
        // \r\n... case
        starts.push(i + 2)
        i += 2
      } else {
        // \r... case
        starts.push(i + 1)
        i += 1
      }
    } else {
      if code == 10 {
        starts.push(i + 1)
      }
      i += 1
    }
  }
  starts
}
