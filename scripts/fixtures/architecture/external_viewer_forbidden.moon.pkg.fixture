// Intentionally named *.fixture so Moon does not discover it as a package.
// check-architecture.mbtx feeds this exact manifest through the external-host
// import policy and requires both deep viewer imports to be rejected.
import {
  "moonbit-community/editor/viewer",
  "moonbit-community/editor/viewer/common/model",
  "moonbit-community/editor/viewer/browser/testing",
  "moonbit-community/editor/viewer/contrib/hover",
}

supported_targets = "js"
